Options -Indexes

# Block direct access to sensitive directories
RewriteEngine On
RewriteRule ^(core|config|scripts)(/|$) - [F,L]

# Pass static files through directly (images, css, js, fonts, etc.)
RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot|map)$ [NC]
RewriteRule ^ - [L]

# Pass themes and public directories through directly
RewriteCond %{REQUEST_URI} ^/(themes|public)/
RewriteRule ^ - [L]

# Allow Let's Encrypt ACME challenges through directly
RewriteCond %{REQUEST_URI} ^/\.well-known/acme-challenge/
RewriteRule ^ - [L]

# Route ALL other requests through the front controller (including PHP files)
RewriteRule ^ index.php [L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHP settings (if using Apache mod_php)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
</IfModule>
