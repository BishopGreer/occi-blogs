Options -Indexes

# Block direct access to sensitive directories
RewriteEngine On
RewriteRule ^(core|config|scripts)(/|$) - [F,L]

# Allow direct access to theme assets, public assets, and uploads
RewriteCond %{REQUEST_URI} ^/themes/ [OR]
RewriteCond %{REQUEST_URI} ^/public/
RewriteRule ^ - [L]

# Allow .well-known through
RewriteCond %{REQUEST_URI} ^/\.well-known/
RewriteRule ^ - [L]

# Route everything else through front controller
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHP settings (if using Apache mod_php)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
</IfModule>
